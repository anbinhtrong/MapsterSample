@model MapsterSample.Models.ProductViewModel

@{
    ViewBag.Title = "Product Details";
}

<h2>Product Information</h2>

<div class="form-group">
    <label>ID:</label>
    <p>@Model.Id</p>
</div>

<div class="form-group">
    <label>Name:</label>
    <p>@Model.Name</p>
</div>

<div class="form-group">
    <label>Price:</label>
    <p>$@Model.Price</p>
</div>

<div class="form-group">
    <label>Description:</label>
    <p>@Model.Description</p>
</div>

<div class="form-group">
    <label>Created Date:</label>
    <p>@Model.CreatedDate.ToString("yyyy-MM-dd")</p>
</div>

<div>
    @Html.ActionLink("Edit", "Edit", "Product", new { id = Model.Id }, new { @class = "btn btn-warning" })
    @Html.ActionLink("Back to Home", "Index", "Home", new { @class = "btn btn-primary" })
</div>
